{
  "name": "RAG Tutorial",

  "dockerComposeFile": "../docker-compose.yml",

  "service": "rag",

  "workspaceFolder": "/app",

  "overrideCommand": true,

  "shutdownAction": "stopCompose",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/app/.venv/bin/python"
      }
    }
  },

  "postCreateCommand": "uv sync --group dev"
}