GROQ_API_KEY=

# Qdrant vector store (src/vectorstore.py -> QdrantVectorStore)
# Local dev: leave both unset - defaults to the "qdrant" service in docker-compose.yml
# Production: point at a Qdrant Cloud cluster (https://cloud.qdrant.io)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
GROQ_API_KEY="your_api_key"
GOOGLE_API_KEY="your_api_key"
LANGSMITH_API_KEY="your_api_key"